{
  "manifest_version": 3,
  "name": "소마 멘토링 캘린더 개선",
  "version": "1.0.0",
  "description": "소프트웨어 마에스트로 멘토링 신청 캘린더 UI 개선 및 멘토 필터링 기능 추가",
  "permissions": [],
  "content_scripts": [
    {
      "matches": ["https://www.swmaestro.ai/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {}
}
